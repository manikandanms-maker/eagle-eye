# Optional. Without it, Eagle Eye uses the built-in offline reasoner (cost = 0).
ANTHROPIC_API_KEY=

# Optional model override (defaults to a fast, cheap model).
EAGLEEYE_MODEL=claude-haiku-4-5

# Magento read-replica (first-check validation + live order fetch).
MAGENTO_DB_HOST=caratlaneliverds-rr.caratlane.com
MAGENTO_DB_NAME=caratlane
MAGENTO_DB_USER=caratlanelive
MAGENTO_DB_PASSWORD=
MAGENTO_DB_PORT=3306

# Oracle Fusion read-only (manufacturing type + inhouse bag / metal loss).
ORACLE_USER=WKSP_XXCL_PRD_READONLY
ORACLE_PASSWORD=
ORACLE_DSN=(description=(retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1522)(host=oxgfzcol.adb.ap-mumbai-1.oraclecloud.com))(connect_data=(service_name=g8e876fb9495e11_caratlaneoicatpprod_high.adb.oraclecloud.com))(security=(ssl_server_dn_match=no)))
ORACLE_WALLET_DIR=/Users/manikandanms/Documents/Wallet_CARATLANEOICATPPROD

# Optional: point the loader at live OIC/Fusion instead of fixtures.
OIC_BASE_URL=
OIC_AUTH_HEADER=

# Fusion BI Publisher SOAP (item ATP / Work Definition / UOM report).
FUSION_SOAP_USER=
FUSION_SOAP_PASSWORD=
FUSION_SOAP_URL=https://iaaycp.fa.ocs.oraclecloud.com/xmlpserver/services/ExternalReportWSSService
FUSION_SCHEDULE_SOAP_URL=https://iaaycp.fa.ocs.oraclecloud.com/xmlpserver/services/v2/ScheduleService
FUSION_REPORT_PATH=/Custom/Extraction Reports/ITEM ATP WD UOM STATUS/item_wd_atp_uom.xdo
FUSION_REPORT_ITEM_PARAM=item_number
FUSION_REPORT_FORMAT=csv
FUSION_REPORT_CACHE_TTL=21600
FUSION_RUN_REPORT_TIMEOUT=180
FUSION_LOCATION_REPORT_PATH=/Custom/Extraction Reports/SaaS_location_barcode_praveen/saas_location_barcode_p.xdo
FUSION_LOCATION_REPORT_PARAM=lot_number
FUSION_TRANSACTION_REPORT_PATH=/Custom/Extraction Reports/Barcode_transaction_type/Barcode_transaction_type_4_RPT.xdo
FUSION_TRANSACTION_REPORT_PARAM=lot_number
# Set to 1 to fetch SaaS location/transaction BI reports per barcode (lot_number param).
FUSION_ENABLE_BARCODE_SAAS_REPORTS=1
FUSION_BARCODE_REPORT_TIMEOUT=45
# Set to 0 to skip per-item SOAP on cache miss (faster validate, ATP shows MISSING).
FUSION_REPORT_SYNC_ON_MISS=1

# Google Chat webhook — posts validation status on every order search.
GOOGLE_CHAT_WEBHOOK_URL=

# SaaS finance reports (AR / AP / WO RM consumption).
FUSION_ENABLE_SAAS_FINANCE_REPORTS=1
FUSION_AR_REPORT_PATH=/Custom/Extraction Reports/AR_Invoices_Praveen/AR_invoices_RPT.xdo
FUSION_AR_INVOICE_PARAM=invoice_number
FUSION_AP_REPORT_PATH=/Custom/Extraction Reports/AP_invoice_ledger_Praveen/AP_Inovice_status_RPT.xdo
FUSION_AP_INVOICE_PARAM=invoice_number
FUSION_WO_RM_REPORT_PATH=/Custom/Extraction Reports/Work_order_rm_consumption_praveen/Work_order_rm_consumption_RPT.xdo
FUSION_WO_RM_PARAM=work_order_number
FUSION_FINANCE_REPORT_TIMEOUT=60
